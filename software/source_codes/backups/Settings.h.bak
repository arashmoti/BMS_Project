typedef union
{
  uint32_t val;
  struct
  {
    uint8_t byte0 : 8;
    uint8_t byte1 : 8;
    uint8_t byte2 : 8;
    uint8_t byte3 : 8;
  };
} dLong;

// ########################################################################################################################################

typedef union
{
  uint16_t val;
  struct
  {
    uint8_t byte0 : 8;
    uint8_t byte1 : 8;
  };
  struct
  {
    uint8_t bit0 : 1;
    uint8_t bit1 : 1;
    uint8_t bit2 : 1;
    uint8_t bit3 : 1;
    uint8_t bit4 : 1;
    uint8_t bit5 : 1;
    uint8_t bit6 : 1;
    uint8_t bit7 : 1;
    uint8_t bit8 : 1;
    uint8_t bit9 : 1;
    uint8_t bit10 : 1;
    uint8_t bit11 : 1;
    uint8_t bit12 : 1;
    uint8_t bit13 : 1;
    uint8_t bit14 : 1;
    uint8_t bit15 : 1;
  };
} dShort;

// ########################################################################################################################################

typedef union
{
  int16_t val;
  struct
  {
    int8_t byte0 : 8;
    int8_t byte1 : 8;
  };
  struct
  {
    int8_t bit0 : 1;
    int8_t bit1 : 1;
    int8_t bit2 : 1;
    int8_t bit3 : 1;
    int8_t bit4 : 1;
    int8_t bit5 : 1;
    int8_t bit6 : 1;
    int8_t bit7 : 1;
    int8_t bit8 : 1;
    int8_t bit9 : 1;
    int8_t bit10 : 1;
    int8_t bit11 : 1;
    int8_t bit12 : 1;
    int8_t bit13 : 1;
    int8_t bit14 : 1;
    int8_t bit15 : 1;
  };
} dIntShort;

