// ########################################################################################################################################

#define ERRORLOG_FILENAME "errorLog.csv"
#define CELL_VOLTAGE_LOG_FILENAME "cellVoltageLog.csv"
#define PACK_TEMPERATURE_LOG_FILENAME "packTemperatureLog.csv"
#define SYSTEM_INFORMATION_LOG_FILENAME "systemInformationLog.csv"

// SD logging: maximum size per file before rotation (bytes).
// Keep comfortably below FAT32 4GB limit; 256MB default is a good balance.
#ifndef SD_LOG_MAX_BYTES
#define SD_LOG_MAX_BYTES (256UL * 1024UL * 1024UL)
#endif

// Maximum number of rotated segments to keep per log file base name.
// When the limit is reached, the oldest segment (smallest index) is deleted on next rotation.
#ifndef SD_LOG_MAX_SEGMENTS
#define SD_LOG_MAX_SEGMENTS 32
#endif

