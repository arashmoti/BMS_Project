#ifndef __SETTINGS__H_
#define __SETTINGS__H_

#include "mbed.h"
#include <cstdint>
#include <vector>

// you should add the mbed_app.json for printing the floatpoint
//  "target.printf_lib": "minimal-printf",
//   "platform.minimal-printf-enable-floating-point": true,
//   "platform.minimal-printf-set-floating-point-max-decimals": 4,

// #define LITHIUM_ION
#define LITHIUM_IRON_PHOSPHATE
#define OLED_ACTIVATION
// #define IS_DEVELOPMENT
// #define USE_PRECHARGE

// TEMPORARY OVERRIDE: Set to 1 to force commissioning mode to be done/bypassed
// Set to 0 to use normal EEPROM-based commissioning logic
#define FORCE_COMMISSIONING_DONE 1

// Set to 1 to completely disable balancing
// Set to 0 to enable normal balancing logic
#define DISABLE_BALANCING 0

// Set to 1 to disable OCV-based SOC correction
// Set to 0 to enable normal OCV correction
#define DISABLE_OCV_CORRECTION 0

// ONE-TIME: Set to 1 to force SOC to 90% and save to EEPROM on boot
// IMPORTANT: Set back to 0 after flashing to avoid resetting SOC on every boot
#define FORCE_SOC_90_PERCENT 0

#define HW_VERSION 100 // PCBs version

#define BQ_MEASUREMENT_COMMS_MAIL_SIZE 32
#define NoOfPROTS_POSSIBLE_ON_SYS 10

#define LOGGING_CELL_VOLTAGE_MAIL_SIZE 32

// ########################################################################################################################################

#define EEPROM_ERROR_INDEX_ADDRESS 400
#define ERROR_START_ADDRESS 200
#define SETTINGS_START_ADDRESS 0
#define SETTINGS_STOP_ADDRESS 198
#define EEPROM_MAPPED_VALUE 0xCA11

// ########################################################################################################################################

#define NoOfCELL_POSSIBLE_ON_CHIP 16
#define NoOfTEMP_POSSIBLE_ON_CHIP 8
#define NoOfCELL_MONITORS_POSSIBLE_ON_BMS 4
#define NoOfTEMP_ACTIVE 8
#define NoOfNTC_TYPE 2

// ########################################################################################################################################

#define PIN_STATE_ENABLE 1
#define PIN_STATE_DISABLE 0

// If your RGB LED is wired active-low (common anode), set to 1 to invert PWM
#ifndef RGB_LED_ACTIVE_LOW
#define RGB_LED_ACTIVE_LOW 0
#endif

// Power button input polarity: 1 = active-low (pressed pulls line low)
#ifndef POWER_BTN_ACTIVE_LOW
#define POWER_BTN_ACTIVE_LOW 0
#endif

// Enable PWM-based LED effects (fade/breathe). Default off to preserve legacy behavior
#ifndef ENABLE_RGB_PWM_EFFECTS
#define ENABLE_RGB_PWM_EFFECTS 0
#endif

// Balancing small-current guard (mA). Shared across modules.
#ifndef BALANCING_MAX_CHARGE_CURRENT_MA
#define BALANCING_MAX_CHARGE_CURRENT_MA 2000
#endif

// Balance selection: enable smooth top-window scaling by dv (default on)
// When enabled, window_mV = clamp(dv/5, 12, 40) instead of tiered 10/20/30 mV
#ifndef ENABLE_SMOOTH_TOP_WINDOW
#define ENABLE_SMOOTH_TOP_WINDOW 1
#endif

// ########################################################################################################################################

#define INTTERFACE_BOOL_TRUE 0xAA
#define INTTERFACE_BOOL_FALSE 0xBB

// ########################################################################################################################################

#define OLED_ADDRESS 0x3C

// ########################################################################################################################################

